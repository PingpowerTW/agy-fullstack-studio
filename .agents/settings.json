{
  "version": "1.0",
  "project": "Antigravity-Full-Stack-Studios",
  "permissions": {
    "allowedCommands": [
      "npm test",
      "npm run dev",
      "docker compose up",
      "git status",
      "git log",
      "git diff"
    ],
    "blockedCommands": [
      "rm -rf",
      "git push --force",
      "cat .env",
      "type .env",
      "Get-Content .env",
      "more .env",
      "less .env",
      "Remove-Item -Recurse -Force"
    ]
  },
  "hooks": {
    "preToolUse": {
      "commands": [
        {
          "name": "secrets-scanner",
          "script": "node .agents/hooks/validate-secrets.js",
          "match": "*"
        }
      ]
    },
    "postToolUse": {
      "commands": [
        {
          "name": "api-schema-validator",
          "script": "node .agents/hooks/validate-api-schema.js",
          "match": "src/frontend/types/**/*.ts|src/backend/**/*.ts"
        },
        {
          "name": "migration-validator",
          "script": "node .agents/hooks/validate-db-migrations.js",
          "match": "src/db/migrations/**/*.{sql,js,ts}"
        }
      ]
    }
  },
  "reviewMode": "lean"
}
